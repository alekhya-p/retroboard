MONGODB_URL=mongodb://YOUR_COSMOS_ACCOUNT:<MONGODB_PASSWORD_PLACEHOLDER>@YOUR_COSMOS_ACCOUNT.mongo.cosmos.azure.com:10255/?ssl=true&retrywrites=false&maxIdleTimeMS=120000&appName=@YOUR_COSMOS_ACCOUNT@
MICROSOFT_CLIENT_ID=YOUR_MICROSOFT_CLIENT_ID
MICROSOFT_CLIENT_SECRET=<MICROSOFT_CLIENT_SECRET_PLACEHOLDER>
MICROSOFT_TENANT_ID=YOUR_MICROSOFT_TENANT_ID
GOOGLE_CLIENT_ID=YOUR_GOOGLE_OAUTH_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CALLBACK_URL=https://reaitro.com/login?provider=google
GOOGLE_CLIENT_SECRET=<GOOGLE_CLIENT_SECRET_PLACEHOLDER>
SECRET_KEY=<SECRET_KEY_PLACEHOLDER>
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CALLBACK_URL=http://localhost:5173/login

# ---- AI provider ----------------------------------------------------------
# Which LLM backend to use: vertex | openai | anthropic
AI_PROVIDER=openai
# OpenAI (or any OpenAI-compatible endpoint: Azure OpenAI, OpenRouter, Ollama…)
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=<OPENAI_API_KEY_PLACEHOLDER>
OPENAI_MODEL=gpt-4o-mini
# Anthropic (Claude) - only needed when AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=<ANTHROPIC_API_KEY_PLACEHOLDER>
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
VERSION=<VERSION>
CALLBACK_URI=/login?provider=google